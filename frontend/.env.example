# ============================================================
#  VYAPARI FRONTEND — ENVIRONMENT VARIABLES
#  Copy to .env.local for local development.
#  NEVER commit .env.local to git.
# ============================================================

# Backend API URL
# Local dev: leave empty (Vite proxy handles /api → localhost:5000)
# Production (Vercel/Netlify): set to your Render/Railway backend URL
VITE_API_URL=

# Example production value:
# VITE_API_URL=https://vyapari-api.onrender.com/api
