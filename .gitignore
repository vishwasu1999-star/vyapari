# ============================================================
# VYAPARI — .gitignore
# ============================================================

# Node dependencies
node_modules/
.pnp
.pnp.js

# Environment secrets — NEVER commit .env files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env

# Build output
dist/
build/
.vite/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Testing
coverage/
.nyc_output/

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Editor directories and files
.vscode/
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# PWA service worker (auto-generated at build time)
frontend/public/sw.js
frontend/public/workbox-*.js
